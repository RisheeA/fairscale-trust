# ─────────────────────────────────────────
# FairScale Trust — Environment Variables
# Copy this to .env.local and fill in values
# ─────────────────────────────────────────

# FairScale API (server-side only — never exposed to browser)
FAIRSCALE_API_KEY=your_fairscale_api_key_here

# FairScale API base URL
NEXT_PUBLIC_FAIRSCALE_API_URL=https://api.fairscale.xyz

# Privy — same App ID as your Credit Engine
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# Supabase — same project as Credit Engine
NEXT_PUBLIC_SUPABASE_URL=https://mdbarsshjmrinutavzdx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
